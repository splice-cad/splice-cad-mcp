{
  "name": "@splice-cad/mcp",
  "version": "0.3.0",
  "description": "MCP server for Splice CAD — search parts, build harness plans, create components with rich specs, and generate manufacturing documentation",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "splice-cad-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "bin",
    "scripts/postinstall.js",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "generate": "tsx scripts/generate-schema.ts && tsx scripts/generate-commands.ts",
    "build": "tsup",
    "build:full": "npm run generate && tsup",
    "prepublishOnly": "npm run build",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/splice-cad/splice-cad-mcp.git"
  },
  "homepage": "https://splice-cad.com",
  "bugs": {
    "url": "https://github.com/splice-cad/splice-cad-mcp/issues"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cable-harness",
    "wiring-diagram",
    "splice",
    "splice-cad",
    "design-automation",
    "ai-tools"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "axios": "^1.9.0",
    "ws": "^8.20.0",
    "zod": "^3.25.11"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/ws": "^8.18.1",
    "ts-json-schema-generator": "^2.9.0",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "~5.5.3",
    "vitest": "^3.2.4"
  }
}
