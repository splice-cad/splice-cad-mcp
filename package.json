{
  "name": "@splice-cad/mcp",
  "version": "0.1.0",
  "description": "MCP server for Splice CAD cable assembly and wiring harness design tool — search parts, build plans, generate assemblies via AI agents",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "splice-mcp": "dist/index.js"
  },
  "scripts": {
    "generate": "tsx scripts/generate-schema.ts && tsx scripts/generate-commands.ts",
    "build": "tsup",
    "build:full": "npm run generate && tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cable-harness",
    "wiring-diagram",
    "splice",
    "splice-cad",
    "design-automation",
    "ai-tools"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "axios": "^1.9.0",
    "ws": "^8.20.0",
    "zod": "^3.25.11"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/ws": "^8.18.1",
    "ts-json-schema-generator": "^2.9.0",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "~5.5.3",
    "vitest": "^3.2.4"
  }
}
